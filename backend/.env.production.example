# SQL Server — PRODUCCIÓN: completar con datos reales
DB_SERVER=tu-servidor-sql-server.database.windows.net
DB_NAME=BizRiseDB
DB_USER=bizrise_user
DB_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO
DB_DRIVER=ODBC Driver 18 for SQL Server

# JWT — generar clave aleatoria de 64+ caracteres
SECRET_KEY=CAMBIAR_POR_CLAVE_ALEATORIA_DE_64_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_NAME=BizRise API
DEBUG=False
ALLOWED_ORIGINS=https://bizrise.vercel.app

# Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=2
