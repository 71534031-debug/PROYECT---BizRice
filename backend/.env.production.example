# PostgreSQL — PRODUCCIÓN: usar URL de Neon/Render/AWS RDS
DATABASE_URL=postgresql://user:password@host:5432/BizRiseDB?sslmode=require

# JWT — generar clave aleatoria de 64+ caracteres
SECRET_KEY=CAMBIAR_POR_CLAVE_ALEATORIA_DE_64_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_NAME=BizRise API
DEBUG=False
ALLOWED_ORIGINS=https://bizrise.vercel.app

# Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=2
